# Android / Gradle build outputs
.gradle/
build/
*/build/
local.properties

# Android Studio IDE files
*.iml
.idea/
.DS_Store

# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
# Keep the Gradle wrapper JAR so the project can bootstrap without a local Gradle install
!gradle/wrapper/gradle-wrapper.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Kotlin Gradle plugin data, see https://kotlinlang.org/docs/whatsnew20.html#new-directory-for-kotlin-data-in-gradle-projects
.kotlin/
.kotlin_module/
.cxx/

*.jks
*.base64
.env*
!infra/docker/.env*

# Python virtual environments
.venv/
venv/
*.pyc
__pycache__/
*.egg-info/

# Pytest cache
.pytest_cache/

# Next.js build output
.next/
node_modules/
package-lock.json